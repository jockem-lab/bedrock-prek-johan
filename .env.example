# Kopiera denna fil till .env och fyll i värden

# WordPress
WP_ENV=development
WP_HOME=http://localhost:8090
WP_SITEURL=${WP_HOME}/wp

# Databas
DB_NAME=bedrock
DB_USER=bedrock
DB_PASSWORD=
DB_HOST=db

# Säkerhetsnycklar - generera på https://roots.io/salts/
AUTH_KEY=
SECURE_AUTH_KEY=
LOGGED_IN_KEY=
NONCE_KEY=
AUTH_SALT=
SECURE_AUTH_SALT=
LOGGED_IN_SALT=
NONCE_SALT=

# ACF Pro licensnyckel
ACF_PRO_KEY=

# FasAD API
# Konfigureras via wp-admin efter installation
