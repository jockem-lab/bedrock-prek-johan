# Comment Reason: https://github.com/joeblau/gitignore.io/issues/186#issuecomment-215987721

# *.iml
# modules.xml

# Exclude vendor and yarn and dist and ... all!
web/app/themes/standardsite/vendor
web/app/themes/standardsite/node_modules
web/app/themes/standardsite/dist
